{
  "manifest_version": 3,
  "name": "Prospecção Maratona",
  "version": "60.0.0",
  "permissions": ["storage"],
  "host_permissions": ["https://app.duleads.com.br/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://app.duleads.com.br/*"],
    "js": ["agents.js", "content.js"],
    "run_at": "document_end"
  }]
}